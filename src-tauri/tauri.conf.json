{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MingXi Desktop",
  "version": "0.1.0",
  "identifier": "com.mingxi.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "明析",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "企业级项目管理桌面应用",
    "longDescription": "明析是一款专业的企业级项目管理软件，提供项目跟踪、任务管理、团队协作等功能",
    "category": "Business"
  }
}